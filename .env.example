# Shopify
SHOPIFY_STORE_URL=example.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_XXXXXXX

# SAP Business ByDesign
SAP_BYD_URL=https://myXXXXXX.sapbydesign.com
SAP_BYD_USERNAME=your_username
SAP_BYD_PASSWORD=your_password

# 3PL (UNIS)
# Production: https://3PLAPI.com
# Staging: https://3PLTESTAPI.com
THREEPL_API_URL=https://3PLAPI.com
THREEPL_USERNAME=3PL_username
THREEPL_PASSWORD=3PL_password
THREEPL_COMPANY_ID=COMPANY
THREEPL_CUSTOMER_ID=CUSTOMERID
THREEPL_FACILITY_ID=FACILITYID

# Thresholds (in minutes) - optional, defaults shown
THRESHOLD_SHOPIFY_TO_SAP=70
THRESHOLD_SAP_TO_3PL_REQUEST=25
THRESHOLD_3PL_REQUEST_TO_RECEIVED=15
THRESHOLD_RECEIVED_TO_SHIPPED=2160
